# Model
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_MAX_MODEL_LEN=
VLLM_DTYPE=auto
VLLM_QUANTIZATION=

# Engine
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.90

# Server
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_MAX_CONCURRENT_REQUESTS=256

# Generation defaults
VLLM_DEFAULT_MAX_TOKENS=1024
VLLM_DEFAULT_TEMPERATURE=0.7

# HuggingFace (required for gated models like Llama)
HF_TOKEN=
