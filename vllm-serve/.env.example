# Model (Qwen is ungated — no HF_TOKEN needed; Llama requires one)
SERVE_MODEL=Qwen/Qwen2.5-7B-Instruct
SERVE_DTYPE=auto

# Engine
SERVE_TENSOR_PARALLEL_SIZE=1
SERVE_GPU_MEMORY_UTILIZATION=0.90

# Server
SERVE_HOST=0.0.0.0
SERVE_PORT=8000
SERVE_MAX_CONCURRENT_REQUESTS=256

# Generation defaults
SERVE_DEFAULT_MAX_TOKENS=1024
SERVE_DEFAULT_TEMPERATURE=0.7

# HuggingFace (required for gated models like Llama)
HF_TOKEN=
